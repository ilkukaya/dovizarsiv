---
import Base from '../../layouts/Base.astro';
import PriceChart from '../../components/charts/PriceChart.tsx';
import { cryptoCurrencies } from '../../lib/currencies';
import { formatDateShort } from '../../lib/formatters';

export function getStaticPaths() {
  return cryptoCurrencies.map(currency => ({
    params: { coin: currency.slug },
    props: { currency },
  }));
}

const { coin } = Astro.params;
const { currency } = Astro.props as { currency: typeof cryptoCurrencies[0] };

const cryptoFiles = import.meta.glob('../../data/crypto/*.json', { eager: true });
const mod = cryptoFiles[`../../data/crypto/${coin}-try.json`];
const allDataRaw = mod ? (mod as any).default : {};

const dates = Object.keys(allDataRaw).sort();
const latestDate = dates[dates.length - 1];
const prevDate = dates[dates.length - 2];
const latest = allDataRaw[latestDate];
const prev = allDataRaw[prevDate];

const change = prev ? ((latest.price - prev.price) / prev.price) * 100 : 0;

const allPrices = dates.map(d => allDataRaw[d].price);
const minPrice = Math.min(...allPrices);
const maxPrice = Math.max(...allPrices);
const avgPrice = allPrices.reduce((a: number, b: number) => a + b, 0) / allPrices.length;

const chartData: Record<string, { buy: number; sell: number }> = {};
dates.forEach(d => {
  chartData[d] = { buy: allDataRaw[d].price, sell: allDataRaw[d].price };
});

const last30Data: Record<string, { buy: number; sell: number }> = {};
dates.slice(-30).forEach(d => {
  last30Data[d] = { buy: allDataRaw[d].price, sell: allDataRaw[d].price };
});
---

<Base title={`${currency?.flag} ${currency?.nameTr} / TL Fiyatı ve Tarihsel Veriler | Döviz Arşiv`}>
  <div class="space-y-8">
    <div class="flex items-center gap-3">
      <span class="text-4xl">{currency?.flag}</span>
      <div>
        <h1 class="text-3xl font-mono font-bold text-white">
          {currency?.nameTr} / Türk Lirası
        </h1>
        <p class="text-gray-400 font-mono text-sm">{currency?.code}/TRY</p>
      </div>
    </div>

    <div class="card p-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <div class="text-gray-400 text-sm mb-1">Fiyat</div>
          <div class="text-2xl font-mono font-bold text-white number">₺{latest.price.toLocaleString('tr-TR', { maximumFractionDigits: 2 })}</div>
        </div>
        <div>
          <div class="text-gray-400 text-sm mb-1">Değişim</div>
          <div class={`text-2xl font-mono font-bold number ${change >= 0 ? 'text-up' : 'text-down'}`}>
            {change >= 0 ? '+' : ''}{change.toFixed(2).replace('.', ',')}%
          </div>
        </div>
        <div>
          <div class="text-gray-400 text-sm mb-1">Tarih</div>
          <div class="text-lg font-mono text-white">{formatDateShort(latestDate)}</div>
        </div>
      </div>
    </div>

    <PriceChart client:load data={chartData} title={`${currency?.nameTr} / TL Grafiği`} />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="card p-5">
        <div class="text-gray-400 text-sm mb-1">En Düşük</div>
        <div class="text-xl font-mono font-bold text-down number">₺{minPrice.toLocaleString('tr-TR', { maximumFractionDigits: 0 })}</div>
      </div>
      <div class="card p-5">
        <div class="text-gray-400 text-sm mb-1">En Yüksek</div>
        <div class="text-xl font-mono font-bold text-up number">₺{maxPrice.toLocaleString('tr-TR', { maximumFractionDigits: 0 })}</div>
      </div>
      <div class="card p-5">
        <div class="text-gray-400 text-sm mb-1">Ortalama</div>
        <div class="text-xl font-mono font-bold text-white number">₺{avgPrice.toLocaleString('tr-TR', { maximumFractionDigits: 0 })}</div>
      </div>
    </div>
  </div>
</Base>
